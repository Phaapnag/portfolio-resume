{
  "framework": "vite",
  "functions": {
    "api/portfolio.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    { "source": "/portfolio.json", "destination": "/portfolio.json" },
    { "source": "/api/portfolio", "destination": "/api/portfolio.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}